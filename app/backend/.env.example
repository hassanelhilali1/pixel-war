# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000
GRID_SIZE=50
LOG_LEVEL=info
FRONTEND_URL=http://localhost

# ── Base de données (Docker Compose) ─────────────────────────────────────────
DATABASE_URL=postgresql://pixelwar:pixelwar@localhost:5432/pixelwar

